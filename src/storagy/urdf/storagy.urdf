<?xml version="1.0" ?>
<robot name="storagy" xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- <xacro:include filename="$(find storagy)/urdf/common_properties.urdf"/> -->

  <!-- Init colour -->
  <material name="black">
      <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <material name="dark">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>

  <material name="light_black">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>

  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>

  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="orange">
    <color rgba="1.0 0.4235 0.0392 1.0"/>
  </material>

  <material name="brown">
    <color rgba="0.8706 0.8118 0.7647 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.065" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0.0 0 0.13" rpy="0 0 0"/>
      <geometry>
        <!-- <mesh filename="package://storagy/meshes/bases/Main.stl" scale="0.01 0.01 0.01"/> -->
        <box size="0.4 0.3 0.26"/>
      </geometry>
      <material name="white"/>
    </visual>

    <collision>
      <origin xyz="-0.064 0 0.047" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.20 0.094"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.3729096e+00"/>
      <inertia ixx="8.7002718e-03" ixy="-4.7576583e-05" ixz="1.1160499e-04"
               iyy="8.6195418e-03" iyz="-3.5422299e-06"
               izz="1.4612727e-02" />
    </inertial>
  </link>

  <joint name="wheel_front_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_left_link"/>
    <origin xyz="0.0 0.1 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="wheel_front_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57 0 0.0"/>
      <geometry>
        <!-- <mesh filename="package://storagy/meshes/wheels/Front_left_wheel.stl" scale="0.01 0.01 0.01"/> -->
        <cylinder length="0.08" radius="0.065"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="-1.57 0 0"/>
      <geometry>
        <cylinder length="0.08" radius="0.065"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="2.8498940e-02" />
      <inertia ixx="1.1175580e-05" ixy="-4.2369783e-11" ixz="-5.9381719e-09"
               iyy="1.1192413e-05" iyz="-1.4400107e-11"
               izz="2.0712558e-05" />
      </inertial>
  </link>

  <joint name="wheel_front_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_right_link"/>
    <origin xyz="0.0 -0.1 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="wheel_front_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57 0 0"/>
      <geometry>
        <!-- <mesh filename="package://storagy/meshes/wheels/Front_right_wheel.stl" scale="0.01 0.01 0.01"/> -->
        <cylinder length="0.08" radius="0.065"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="-1.57 0 0"/>
      <geometry>
        <cylinder length="0.08" radius="0.065"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="2.8498940e-02" />
      <inertia ixx="1.1175580e-05" ixy="-4.2369783e-11" ixz="-5.9381719e-09"
               iyy="1.1192413e-05" iyz="-1.4400107e-11"
               izz="2.0712558e-05" />
      </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0 0.068" rpy="0 0 0"/>
  </joint>

  <link name="imu_link"/>

  <joint name="front_scan_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_base_scan"/>
    <origin xyz="0.1525 0.0 0.062" rpy="3.142857143 0 0"/>
  </joint>

  <link name="front_base_scan">
    <visual>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://storagy/meshes/sensors/lidar.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0.015 0 -0.0065" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.0315" radius="0.055"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.114" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001" />
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.198 0.0 0.2295" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://storagy/meshes/sensors/camera.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="light_black"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://storagy/meshes/sensors/camera.stl" scale="0.01 0.01 0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001" />
    </inertial>
  </link>

  <joint name="camera_rgb_joint" type="fixed">
    <!-- <origin xyz="0.003 0.011 0.009" rpy="3.14 0 0"/> -->
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="camera_link"/>
    <child link="camera_rgb_frame"/>
  </joint>
  <link name="camera_rgb_frame"/>

  <joint name="camera_rgb_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.57 0 -1.57"/>
    <parent link="camera_rgb_frame"/>
    <child link="camera_color_optical_frame"/>
  </joint>
  <link name="camera_color_optical_frame"/>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_front_left_joint</left_joint>
      <right_joint>wheel_front_right_joint</right_joint>
      <wheel_separation>0.2</wheel_separation>
      <wheel_diameter>0.13</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>model/storagy/dummy_odometry</odom_topic>
      <tf_topic>model/storagy/dummy_tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <publish_odom>false</publish_odom>
      <publish_odom_tf>false</publish_odom_tf>
    </plugin>
    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_topic>model/storagy/odometry</odom_topic>
      <tf_topic>model/storagy/tf</tf_topic>
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

  <gazebo reference="front_base_scan">
    <sensor type="gpu_lidar" name="front_lidar">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>15</update_rate>
      <topic>scan</topic>
      <gz_frame_id>front_base_scan</gz_frame_id>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.141592</min_angle>
            <max_angle>3.141592</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor type="rgbd_camera" name="camera">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>15</update_rate>
      <camera>
        <horizontal_fov>1.089</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
      </camera>
      <topic>camera</topic>
    </sensor>
  </gazebo>

  <!-- NOTE: Sensors system plugin is already loaded by the world (room1.sdf).
       Do NOT add it again here, otherwise two Sensors systems try to create
       the rendering scene "scene" and the server segfaults. -->
  <!-- Caster Front Left -->
  <joint name="caster_front_left_swivel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="caster_front_left_swivel_link"/>
    <origin xyz="0.15 0.11 -0.01" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="caster_front_left_swivel_link">
    <visual>
      <origin xyz="-0.0075 0 -0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="-0.0075 0 -0.01" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="caster_front_left_wheel_joint" type="continuous">
    <parent link="caster_front_left_swivel_link"/>
    <child link="caster_front_left_wheel_link"/>
    <origin xyz="-0.015 0.0 -0.019" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="caster_front_left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.570796327 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.035"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.570796327 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.030"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- Caster Front Right -->
  <joint name="caster_front_right_swivel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="caster_front_right_swivel_link"/>
    <origin xyz="0.15 -0.11 -0.01" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="caster_front_right_swivel_link">
    <visual>
      <origin xyz="-0.0075 0 -0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="-0.0075 0 -0.01" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="caster_front_right_wheel_joint" type="continuous">
    <parent link="caster_front_right_swivel_link"/>
    <child link="caster_front_right_wheel_link"/>
    <origin xyz="-0.015 0.0 -0.019" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="caster_front_right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.570796327 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.035"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.570796327 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.030"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- Caster Back Left -->
  <joint name="caster_back_left_swivel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="caster_back_left_swivel_link"/>
    <origin xyz="-0.15 0.11 -0.01" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="caster_back_left_swivel_link">
    <visual>
      <origin xyz="-0.0075 0 -0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="-0.0075 0 -0.01" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="caster_back_left_wheel_joint" type="continuous">
    <parent link="caster_back_left_swivel_link"/>
    <child link="caster_back_left_wheel_link"/>
    <origin xyz="-0.015 0.0 -0.019" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="caster_back_left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.570796327 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.035"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.570796327 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.030"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- Caster Back Right -->
  <joint name="caster_back_right_swivel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="caster_back_right_swivel_link"/>
    <origin xyz="-0.15 -0.11 -0.01" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="caster_back_right_swivel_link">
    <visual>
      <origin xyz="-0.0075 0 -0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="-0.0075 0 -0.01" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="caster_back_right_wheel_joint" type="continuous">
    <parent link="caster_back_right_swivel_link"/>
    <child link="caster_back_right_wheel_link"/>
    <origin xyz="-0.015 0.0 -0.019" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <link name="caster_back_right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.570796327 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.035"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.570796327 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.030"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- Gazebo contact and friction parameters -->
  <gazebo reference="caster_front_left_wheel_link">
    <mu1 value="0.0"/>
    <mu2 value="0.0"/>
    <kp value="1000000.0"/>
    <kd value="100.0"/>
    <minDepth value="0.001"/>
  </gazebo>
  <gazebo reference="caster_front_right_wheel_link">
    <mu1 value="0.0"/>
    <mu2 value="0.0"/>
    <kp value="1000000.0"/>
    <kd value="100.0"/>
    <minDepth value="0.001"/>
  </gazebo>
  <gazebo reference="caster_back_left_wheel_link">
    <mu1 value="0.0"/>
    <mu2 value="0.0"/>
    <kp value="1000000.0"/>
    <kd value="100.0"/>
    <minDepth value="0.001"/>
  </gazebo>
  <gazebo reference="caster_back_right_wheel_link">
    <mu1 value="0.0"/>
    <mu2 value="0.0"/>
    <kp value="1000000.0"/>
    <kd value="100.0"/>
    <minDepth value="0.001"/>
  </gazebo>

  <gazebo reference="wheel_front_left_link">
    <mu1 value="1.5"/>
    <mu2 value="1.5"/>
    <kp value="1000000.0"/>
    <kd value="100.0"/>
    <minDepth value="0.001"/>
  </gazebo>
  <gazebo reference="wheel_front_right_link">
    <mu1 value="1.5"/>
    <mu2 value="1.5"/>
    <kp value="1000000.0"/>
    <kd value="100.0"/>
    <minDepth value="0.001"/>
  </gazebo>

</robot>
